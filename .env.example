# Copy this file to .env and replace values for your environment.
# PowerShell: Copy-Item .env.example .env
# Bash:       cp .env.example .env

# Required for map features.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Required for user password hashing consistency.
# Keep this value stable across deployments.
PASSWORD_PEPPER=your_strong_password_pepper

# Optional placeholders for external API integrations.
API_BASE_URL=
AUTH_API_KEY=

# Optional: Cloudinary config for profile image upload/delete.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=dwrf0xt1x

# Optional fallback password used by admin user creation flow.
DEFAULT_USER_PASSWORD=worksmart123
